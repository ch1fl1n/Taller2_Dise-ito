<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
  
<mapper namespace="edu.unisabana.dyas.sampleprj.dao.mybatis.mappers.ClienteMapper">

    <!-- ============================================ -->
    <!-- PUNTO 3: Select consultarClientes (SE MANTIENE) -->
    <!-- ============================================ -->
    <select id="consultarClientes" parameterType="map" resultMap="ClienteResult">
        select
         c.nombre,
         c.documento,
         c.telefono,
         c.direccion,
         c.email,
         c.vetado,

            datetime(ir.fechainiciorenta) as fechainiciorenta,
            datetime(ir.fechafinrenta) as fechafinrenta,

            i.id as i_id,
            i.nombre as i_nombre,
            i.descripcion,
            datetime(i.fechaLanzamiento) as fechaLanzamiento,
            i.tarifaxdia,
            i.formatorenta,
            i.genero,

            ti.id as ti_id,
            ti.descripcion as ti_descripcion
        FROM VI_CLIENTES as c
        left join VI_ITEMRENTADO as ir on c.documento=ir.CLIENTES_documento
        left join VI_ITEMS as i on ir.ITEMS_id=i.id
        left join VI_TIPOITEM as ti on i.TIPOITEM_id=ti.id
    </select>


    <!-- ============================================ -->
    <!-- PUNTO 4: ResultMap Cliente (SE MANTIENE) -->
    <!-- ============================================ -->
    <resultMap type="Cliente" id="ClienteResult">

        <id property="documento" column="documento"/>
        <result property="nombre" column="nombre"/>
        <result property="telefono" column="telefono"/>
        <result property="direccion" column="direccion"/>
        <result property="email" column="email"/>
        <result property="vetado" column="vetado"/>
        
        <!-- Relación 1:N con ItemRentado -->
        <collection property="rentados"
                    ofType="ItemRentado"
                    resultMap="ItemRentadoResult"/>
    </resultMap>


    <!-- ============================================ -->
    <!-- RESULTMAP ItemRentado -->
    <!-- ============================================ -->
    <resultMap type="ItemRentado" id="ItemRentadoResult">

        <result property="fechainiciorenta" column="fechainiciorenta"/>
        <result property="fechafinrenta" column="fechafinrenta"/>

        <association property="item"
                 javaType="Item"
                 resultMap="ItemResult"/>
    </resultMap>


    <!-- ============================================ -->
    <!-- RESULTMAP Item -->
    <!-- ============================================ -->
    <resultMap type="Item" id="ItemResult">

        <id property="id" column="i_id"/>
        <result property="nombre" column="i_nombre"/>
        <result property="descripcion" column="descripcion"/>
        <result property="fechaLanzamiento" column="fechalanzamiento"/>
        <result property="tarifaxDia" column="tarifaxdia"/>
        <result property="formatoRenta" column="formatorenta"/>
        <result property="genero" column="genero"/>
        
        <!-- Relación 1:1 con TipoItem -->
        <association property="tipo"
                     javaType="TipoItem"
                     resultMap="TipoItemResult"/>
    </resultMap>


    <!-- ============================================ -->
    <!-- RESULTMAP TipoItem -->
    <!-- ============================================ -->
    <resultMap type="TipoItem" id="TipoItemResult">

        <id property="id" column="ti_id"/>
        <result property="descripcion" column="ti_descripcion"/>

    </resultMap>

</mapper>